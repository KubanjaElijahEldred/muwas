MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/muwas-distilling
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
FRONTEND_URL=http://localhost:5173,http://localhost:5174
PORT=5000
NODE_ENV=development
DB_RETRY_DELAY_MS=3000
DB_MAX_RETRIES=10
# Allow API to boot in development even when MongoDB is offline.
ALLOW_START_WITHOUT_DB=true
# How often to retry connecting to MongoDB while running in fallback mode.
DB_RECONNECT_INTERVAL_MS=30000
AUTO_SEED_ADMIN=false
DEFAULT_ADMIN_EMAIL=admin@muwasdistilling.ug
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_NAME=Admin User
# Super admin direct sign-in (no admin registration needed).
SUPER_ADMIN_ENABLED=true
SUPER_ADMIN_EMAIL=bryan@muwas.ca
SUPER_ADMIN_USERNAME=bryan anderson
SUPER_ADMIN_NAME=Bryan Anderson
# Allow direct admin signup from /register.
ALLOW_ADMIN_SELF_REGISTER=false
# Optional shared code required when role=admin is selected during registration.
ADMIN_INVITE_CODE=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# MTN Mobile Money
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_TARGET_ENVIRONMENT=sandbox
MTN_MOMO_COLLECTION_SUBSCRIPTION_KEY=your-collection-subscription-key
MTN_MOMO_API_USER=your-api-user-uuid
MTN_MOMO_API_KEY=your-api-key
MTN_MOMO_CURRENCY=UGX
MTN_MOMO_FALLBACK_CURRENCIES=EUR
MTN_MOMO_COUNTRY_CODE=256
MTN_MOMO_CALLBACK_BASE_URL=https://your-public-api-host
MTN_MOMO_PAYER_MESSAGE=Payment for your Muwas order
MTN_MOMO_PAYEE_NOTE=Muwas Distilling checkout
MTN_MOMO_REQUEST_TIMEOUT_MS=20000

# Airtel Money
AIRTEL_MONEY_BASE_URL=https://openapiuat.airtel.africa
AIRTEL_MONEY_CLIENT_ID=your-airtel-client-id
AIRTEL_MONEY_CLIENT_SECRET=your-airtel-client-secret
AIRTEL_MONEY_GRANT_TYPE=client_credentials
AIRTEL_MONEY_COUNTRY=UG
AIRTEL_MONEY_CURRENCY=UGX
AIRTEL_MONEY_COUNTRY_CODE=256
AIRTEL_MONEY_REQUEST_TIMEOUT_MS=20000
